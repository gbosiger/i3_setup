{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "upgrade": {
    "source": "cdn",
    "interval": "168h",
    "auto": false,
    "notice": false
  },
  "palette": {
    "pink": "5",
    "mauve": "6",
    "blue": "blue",
    "green": "green",
    "red": "red",
    "surface0": "8",
    "surface1": "0",
    "text": "3",
    "base": "transparent",
    "mantle": "15"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "background": "p:mauve",
          "foreground": "p:base",
          "style": "diamond",
          "template": "{{ if eq .Env.OMP_PROMPT_MODE \"full\" }}{{if .Root}} \uf0e7 {{.UserName}} {{else}} {{.UserName}} {{end}}{{ end }}",
          "type": "session"
        },
        {
          "background": "p:blue",
          "foreground": "p:base",
          "powerline_symbol": "\ue0b4",
          "properties": {
            "folder_icon": "\uf115",
            "folder_separator_icon": " | ",
            "max_depth": 2,
            "style": "agnoster_short"
          },
          "style": "powerline",
          "template": "{{ if eq .Env.OMP_PROMPT_MODE \"full\" }} {{ .Path }} {{ end }}",
          "type": "path"
        },
        {
          "properties": {
            "branch_icon": "\ue0a0 ",
            "fetch_stash_count": true,
            "fetch_status": true
          },
          "powerline_symbol": "\ue0b4",
          "template": "{{ if eq .Env.OMP_PROMPT_MODE \"full\" }} {{ .UpstreamIcon }}{{ .HEAD }} {{ end }}",
          "foreground": "p:blue",
          "background": "p:surface0",
          "type": "git",
          "style": "powerline"
        },
        {
          "background": "p:mantle",
          "foreground": "p:text",
          "trailing_diamond": "\ue0b4",
          "style": "diamond",
          "type": "os"
        }
      ]
    }
  ],
  "version": 3,
  "final_space": true
}
