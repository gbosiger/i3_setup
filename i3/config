# Regolith-first i3 config
#
# Keep Regolith defaults (keybindings, help overlay, applets like bluetooth, etc.)
# and layer custom theming/startup on top.

include /etc/regolith/i3/config

# Local overlays from this repo
include ~/.config/i3/config.d/*.conf

# Session helpers
bindsym $mod+Control+s exec --no-startup-id systemctl suspend

# Visual stack
exec_always --no-startup-id picom --config ~/.config/picom/picom.conf
exec_always --no-startup-id ~/.config/polybar/launch.sh
